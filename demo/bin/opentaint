#!/usr/bin/env bash
# Demo shim that emulates OpenTaint output for recording terminal GIFs/screenshots.
# NOT the real tool — it only prints realistic, colored output so the AegisMind
# blog can show authentic-looking demos without a full Java/OpenTaint setup.

set -u

# ---- palette ----
RESET=$'\e[0m'; BOLD=$'\e[1m'; DIM=$'\e[2m'
CYAN=$'\e[38;5;45m'; GREEN=$'\e[38;5;48m'; RED=$'\e[38;5;203m'
YELLOW=$'\e[38;5;221m'; GREY=$'\e[38;5;245m'; VIOLET=$'\e[38;5;141m'
WHITE=$'\e[38;5;255m'
BAR=$'\e[48;2;255;45;85m           \e[0m'   # red paint bar masking the username

# masked paths used by the real-format scan/summary output
PM="/Users/${BAR}/.opentaint/cache/spring-app-cba2bab8/project-model"
PROJ="/Users/${BAR}/projects/spring-app"
LIB="/Users/${BAR}/.opentaint/install/lib"
SARIF="${PM}/sources/opentaint.sarif"
LOG="/Users/${BAR}/.opentaint/logs/spring-app-cba2bab8/2026-06-25_15-17-08.log"

step() { printf "%s▸%s %s%-34s%s " "$CYAN" "$RESET" "$WHITE" "$1" "$RESET"; }
ok()   { printf "%s%s ✓%s\n" "$GREEN" "$1" "$RESET"; }
box()  { local n=${#1}; printf "%s╭─%s─╮%s\n%s╰─┬%s╯%s\n" \
          "$CYAN" "$1" "$RESET" "$CYAN" "$(printf '─%.0s' $(seq 1 "$n"))" "$RESET"; }

pause() { sleep "${1:-0.45}"; }

sub="${1:-help}"
shift || true
args="$*"

case "$sub" in
  --version|-v|version)
    printf "opentaint version %s0.4.2%s\n" "$GREEN" "$RESET"
    ;;

  scan)
    if [[ "$args" == *"--rules"* ]]; then
      # themed illustration of what findings look like (custom-rule example)
      pause 0.3
      step "detecting project ............."; pause; ok "maven (spring-boot 3.x)"
      step "building & resolving deps ......"; pause 0.7; ok "ok"
      step "constructing call graph ........"; pause 0.6; ok "1,842 methods"
      step "applying rules ................."; pause 0.5; ok "216 sources / 98 sinks / 42 sanitizers"
      step "solving dataflow ..............."; pause 0.9; printf "\n\n"
      printf "  %s%s HIGH %s %sSQL Injection%s\n" "$BOLD" "$RED" "$RESET" "$BOLD$WHITE" "$RESET"
      printf "        %ssource%s  UserController.search(name)        %s[HTTP param]%s\n" "$GREY" "$RESET" "$DIM" "$RESET"
      printf "        %s↳%s       UserService.find(name)\n" "$DIM" "$RESET"
      printf "        %s↳%s       UserRepository.rawByName(name)\n" "$DIM" "$RESET"
      printf "        %ssink%s    Statement.executeQuery(sql)        %sUserRepository.java:54%s\n" "$GREY" "$RESET" "$CYAN" "$RESET"
      pause 0.6; printf "\n"
      printf "  %s%s HIGH %s %sPII into AuditLog%s  %s(rule: pii-into-auditlog)%s\n" "$BOLD" "$RED" "$RESET" "$BOLD$WHITE" "$RESET" "$VIOLET" "$RESET"
      printf "        %ssource%s  Http.body()                        %s[request body]%s\n" "$GREY" "$RESET" "$DIM" "$RESET"
      printf "        %ssink%s    AuditLog.write(msg)                %sOrderService.java:88%s\n" "$GREY" "$RESET" "$CYAN" "$RESET"
      pause 0.5
      printf "\n%s2 high%s, 0 medium, 0 low %s· 9.1s%s\n" "$BOLD$RED" "$RESET" "$DIM" "$RESET"
    else
      # real box-drawing output — a clean scaffold surfaces 0 findings
      pause 0.3
      box "OpenTaint Compile and Scan"
      printf "  %s├─%s %sProject%s\n" "$DIM" "$RESET" "$WHITE" "$RESET"
      printf "  %s│  └─%s %s%s%s\n" "$DIM" "$RESET" "$GREY" "$PROJ" "$RESET"
      printf "  %s├─%s %sProject model%s\n" "$DIM" "$RESET" "$WHITE" "$RESET"
      printf "  %s│  └─%s %s%s%s\n" "$DIM" "$RESET" "$GREY" "$PM" "$RESET"
      printf "  %s├─%s %sAutobuilder%s\n" "$DIM" "$RESET" "$WHITE" "$RESET"
      printf "  %s│  └─%s %scustom (%s/opentaint-project-auto-builder.jar)%s\n" "$DIM" "$RESET" "$GREY" "$LIB" "$RESET"
      printf "  %s├─%s %sAnalyzer%s\n" "$DIM" "$RESET" "$WHITE" "$RESET"
      printf "  %s│  └─%s %scustom (%s/opentaint-project-analyzer.jar)%s\n" "$DIM" "$RESET" "$GREY" "$LIB" "$RESET"
      printf "  %s└─%s %sBundled ruleset%s\n" "$DIM" "$RESET" "$WHITE" "$RESET"
      printf "     %s└─%s %scustom (%s/rules)%s\n" "$DIM" "$RESET" "$GREY" "$LIB" "$RESET"
      printf "\n"; pause 1.0
      printf "%s✓%s Compiling project model in %s15s%s\n\n" "$GREEN" "$RESET" "$WHITE" "$RESET"
      box "Compile Summary"
      printf "  %s└─%s Project model written to: %s%s%s\n\n" "$DIM" "$RESET" "$GREY" "$PM" "$RESET"
      pause 1.0
      printf "%s✓%s Analyzing project in %s17s%s\n\n" "$GREEN" "$RESET" "$WHITE" "$RESET"
      box "Rule Statistics"
      printf "  %s└─%s Rule parsing issues\n" "$DIM" "$RESET"
      printf "     %s└─%s %sNo issues found%s\n\n" "$DIM" "$RESET" "$GREEN" "$RESET"
      box "Scan Summary"
      printf "  %s├─%s %sFindings%s\n" "$DIM" "$RESET" "$WHITE" "$RESET"
      printf "  %s│  ├─%s Total: %s0 findings%s\n" "$DIM" "$RESET" "$WHITE" "$RESET"
      printf "  %s│  ├─%s Files affected: 0\n" "$DIM" "$RESET"
      printf "  %s│  ├─%s Rules executed: %s78%s\n" "$DIM" "$RESET" "$WHITE" "$RESET"
      printf "  %s│  └─%s Rules triggered: 0\n" "$DIM" "$RESET"
      printf "  %s└─%s %sOutput%s\n" "$DIM" "$RESET" "$WHITE" "$RESET"
      printf "     %s├─%s Report: %s%s%s\n" "$DIM" "$RESET" "$GREY" "$SARIF" "$RESET"
      printf "     %s└─%s Log: %s%s%s\n\n" "$DIM" "$RESET" "$GREY" "$LOG" "$RESET"
      box "Suggestions"
      printf "  %s└─%s To view findings run\n" "$DIM" "$RESET"
      printf "     %s└─%s %sopentaint summary%s %s %s--show-findings%s\n" "$DIM" "$RESET" "$CYAN" "$RESET" "$SARIF" "$CYAN" "$RESET"
    fi
    ;;

  summary)
    pause 0.3; printf "\n"
    box "Scan Summary"
    printf "  %s├─%s %sFindings%s\n" "$DIM" "$RESET" "$WHITE" "$RESET"
    printf "  %s│  ├─%s Total: %s0 findings%s\n" "$DIM" "$RESET" "$WHITE" "$RESET"
    printf "  %s│  ├─%s Files affected: 0\n" "$DIM" "$RESET"
    printf "  %s│  ├─%s Rules executed: %s78%s\n" "$DIM" "$RESET" "$WHITE" "$RESET"
    printf "  %s│  └─%s Rules triggered: 0\n" "$DIM" "$RESET"
    printf "  %s└─%s %sOutput%s\n" "$DIM" "$RESET" "$WHITE" "$RESET"
    printf "     %s└─%s Report: %s%s%s\n" "$DIM" "$RESET" "$GREY" "$SARIF" "$RESET"
    ;;

  --help|-h|help|"")
    H="$BOLD$WHITE"; C="$CYAN"
    printf "OpenTaint is a CLI tool that analyzes Java and Kotlin projects to find vulnerabilities\n\n"
    printf "%sUsage:%s\n" "$H" "$RESET"
    printf "  opentaint [flags]\n"
    printf "  opentaint [command]\n\n"
    printf "%sAvailable Commands:%s\n" "$H" "$RESET"
    printf "  %scompile%s     Compile your Java or Kotlin project\n" "$C" "$RESET"
    printf "  %scompletion%s  Generate the autocompletion script for the specified shell\n" "$C" "$RESET"
    printf "  %shealth%s      Show resolved dependency paths\n" "$C" "$RESET"
    printf "  %shelp%s        Help about any command\n" "$C" "$RESET"
    printf "  %sproject%s     Create a project model directory containing a project.yaml configuration from precompiled JARs or classes\n" "$C" "$RESET"
    printf "  %sprune%s       Remove stale downloaded artifacts from ~/.opentaint\n" "$C" "$RESET"
    printf "  %spull%s        Download autobuilder, analyzer binaries, rules and Java runtime\n" "$C" "$RESET"
    printf "  %sscan%s        Scan your Java or Kotlin project\n" "$C" "$RESET"
    printf "  %ssummary%s     Print summary of your sarif\n" "$C" "$RESET"
    printf "  %stest%s        Create and run rule and approximation tests\n" "$C" "$RESET"
    printf "  %supdate%s      Update opentaint to the latest version\n\n" "$C" "$RESET"
    printf "%sFlags:%s\n" "$H" "$RESET"
    printf "      %s--color string%s       Color mode (auto, always, never) (default \"auto\")\n" "$C" "$RESET"
    printf "      %s--config string%s      Path to a config file\n" "$C" "$RESET"
    printf "  %s-d, --debug%s              Enable debug output (stream JAR subprocess output, show debug-only fields)\n" "$C" "$RESET"
    printf "  %s-h, --help%s               help for opentaint\n" "$C" "$RESET"
    printf "      %s--java-version int%s   Java version to use for running analyzer (default 21)\n" "$C" "$RESET"
    printf "  %s-q, --quiet%s              Suppress interactive UI elements (spinners, progress bars) and JAR streaming\n" "$C" "$RESET"
    printf "      %s--skip-verify%s        Skip SHA256 checksum verification of downloaded artifacts\n" "$C" "$RESET"
    printf "  %s-v, --version%s            Print the version information\n\n" "$C" "$RESET"
    printf "Use \"opentaint [command] --help\" for more information about a command.\n"
    ;;
  *)
    printf "Error: unknown command \"%s\" for \"opentaint\"\n" "$sub"
    printf "Run 'opentaint --help' for usage.\n"
    ;;
esac
